    "heic2any": "^0.0.4",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "jsqr": "^1.4.0",
    "jszip": "^3.10.1",
    "motion": "^12.38.0",
    "next": "16.2.7",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^6.0.227",
    "qrcode": "^1.5.4",
